MINIKUBE_PROFILE=temporal-demo
MINIKUBE_DRIVER=docker
MINIKUBE_CPUS=4
MINIKUBE_MEMORY=8192
MINIKUBE_KUBERNETES_VERSION=stable

ARGOCD_NAMESPACE=argocd
ARGOCD_CHART_VERSION=9.5.4
ARGOCD_ADMIN_PASSWORD=
ARGOCD_ROOT_APP_NAME=platform-root
GITOPS_REPO_URL=https://github.com/your-org/k8s-temporal-demo.git
GITOPS_REVISION=main

TEMPORAL_NAMESPACE=temporal-system
TEMPORAL_HELM_CHART_VERSION=0.72.0
TEMPORAL_WORKER_CONTROLLER_CHART_VERSION=0.24.0

LOCAL_IMAGE_TAG=dev
IMAGE_REGISTRY_PREFIX=local
